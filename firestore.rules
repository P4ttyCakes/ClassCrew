rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isConversationMember(conversation) {
      return isSignedIn() && request.auth.uid in conversation.memberIds;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /conversations/{conversationId} {
      allow create: if isSignedIn() &&
        request.resource.data.memberIds is list &&
        request.auth.uid in request.resource.data.memberIds;

      allow read, update: if resource.data.memberIds is list && isConversationMember(resource.data);

      // Prevent destructive deletes; restrict to members only
      allow delete: if isConversationMember(resource.data);

      match /messages/{messageId} {
        // Only members can read messages
        allow read: if isConversationMember(get(/databases/$(database)/documents/conversations/$(conversationId)).data);

        // Only members can create; messages become immutable
        allow create: if isConversationMember(get(/databases/$(database)/documents/conversations/$(conversationId)).data) &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.createdAt == request.time &&
          request.resource.data.type in ['text','image','file'];

        allow update, delete: if false; // immutable messages
      }
    }
  }
}


